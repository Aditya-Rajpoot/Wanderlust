<% layout("/layouts/boilerplate") %>

<div class="auth-wrapper">
  <div class="auth-card">
    <h2 class="auth-title">Welcome <span>Back</span></h2>
    <form action="/login" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          name="username"
          id="username"
          type="text"
          class="form-control"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          name="password"
          id="password"
          type="password"
          class="form-control"
          required
        />
      </div>

      <button class="btn auth-btn">Login</button>
    </form>
    <p class="auth-footer-text">New here? <a href="/signup">Create an account</a></p>
  </div>
</div>